# Firebase Functions — Variables de entorno para emulator local
# Copia este archivo como .env.local y completa los valores reales
# NUNCA subas .env.local a git

# ── Twilio ────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# Sandbox de Twilio (pruebas): whatsapp:+14155238886
# Producción: whatsapp:+51XXXXXXXXX (tu número aprobado)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Meta Lead Ads ─────────────────────────────────────────────────────────
# Token de verificación: lo defines tú, debe coincidir con el webhook en Meta
META_VERIFY_TOKEN=tw-caficultores-2026
# App Secret: Meta for Developers → tu App → Configuración básica → App Secret
META_APP_SECRET=your_meta_app_secret_here
# Page Access Token: Meta for Developers → Herramientas → Token de acceso de página
META_PAGE_ACCESS_TOKEN=your_page_access_token_here
